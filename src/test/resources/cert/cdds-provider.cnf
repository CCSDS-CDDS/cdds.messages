[ req ]
default_bits       = 4096
prompt             = no
default_md         = sha256
distinguished_name = dn
req_extensions     = req_ext

[ dn ]
C  = EU
O  = CDDS
OU = Provider
CN = theSpacecraft

[ req_ext ]
subjectAltName = @alt_names
extendedKeyUsage = serverAuth

[ alt_names ]
DNS.1 = theSpacecraft
DNS.2 = localhost
IP.1  = 127.0.0.1
